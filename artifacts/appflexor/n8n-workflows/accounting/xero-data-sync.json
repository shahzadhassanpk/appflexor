    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let account = item.json;\n\n// Build text for embedding\nlet textForEmbedding = `Account Name: ${account.Name}.\nType: ${account.Type || \"Unknown\"}, Class: ${account.Class || \"Unknown\"}, Tax Type: ${account.TaxType || \"None\"}.\nCurrency: ${account.CurrencyCode || \"Unknown\"}, Bank Account Number: ${account.BankAccountNumber || \"N/A\"}.\nReporting Code: ${account.ReportingCode || \"N/A\"} (${account.ReportingCodeName || \"\"}).\nStatus: ${account.Status || \"Unknown\"}.\nIntegration: ${account.integration_id || \"N/A\"}.`;\n\n// Build record\nlet record = {\n    formId: \"chart_of_accounts\",\n    entity: \"chart_of_accounts\",\n    action: \"update\",\n    id: account.id || \"new\",\n    formData: {\n        org_id: $('Prepare Database1').first().json.c_org_id,\n        integration: $('Prepare Database1').first().json.id,\n        name: account.Name,\n        status: account.Status,\n        description: account.Description || \"\",\n        code: account.Code || \"\",\n        currency: account.CurrencyCode || \"\",\n        tax_type: account.TaxType?.toLowerCase() || \"\",\n        type: account.Type?.toLowerCase() || \"\",\n        account_type: account.Class?.toLowerCase() || \"\",\n        bank_account_number: account.BankAccountNumber || \"\",\n        bank_account_type: account.BankAccountType || \"\",\n        reporting_code: account.ReportingCode || \"\",\n        reporting_code_name: account.ReportingCodeName || \"\",\n        id: account.id || \"new\",\n        external_id: account.AccountID,\n        text: textForEmbedding // ready for embedding\n    }\n};\n\nreturn record;\n"
      },
