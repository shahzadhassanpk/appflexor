    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let contact = item.json;\n\n// Format addresses\nlet addresses = [];\nif (contact.Addresses && contact.Addresses.length > 0) {\n    addresses = contact.Addresses.map(addr => {\n        // Include full address fields if available, else type only\n        return addr.Address || addr.AddressType || \"\";\n    });\n}\nlet addressesText = addresses.join(\"; \");\n\n// Format phones\nlet phones = [];\nif (contact.Phones && contact.Phones.length > 0) {\n    phones = contact.Phones.map(ph => {\n        // Include number if available, else type only\n        return ph.Phone || ph.PhoneType || \"\";\n    });\n}\nlet phonesText = phones.join(\"; \");\n\n// Build text for embedding\nlet textForEmbedding = `Name: ${contact.Name}. \nType: Customer: ${contact.IsCustomer}, Vendor: ${contact.IsSupplier}. \nAddresses: ${addressesText || \"None\"}. \nPhones: ${phonesText || \"None\"}. \nStatus: ${contact.ContactStatus || \"Unknown\"}.`;\n\n// Build record\nlet record = {\n    formId: \"party\",\n    entity: \"party\",\n    action: \"update\",\n    id: contact.id, // fallback\n    formData: {\n       id: contact.id,\n        org_id: $('Prepare Database1').first().json.c_org_id,\n        integration: $('Prepare Database1').first().json.id,\n        name: contact.Name,\n        is_customer: contact.IsCustomer,\n        is_bank: \"\",\n        is_vendor: contact.IsSupplier,\n        external_id: contact.ContactID,\n        contact_id: contact.id || contact.ContactID,\n        addresses: addressesText,\n        phones: phonesText,\n        contact_status: contact.ContactStatus,\n        text: textForEmbedding // ready for Ollama embedding\n    }\n};\n\nreturn record;\n"
      },
