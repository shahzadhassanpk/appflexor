    {
      "parameters": {
        "jsCode": "let contacts = $input.first().json.Contacts; // array of contacts from Xero\n\nlet request = {\n  tenant_id: $('Prepare Database1').first().json.c_datasource,\n  saveOrUpdate: \"Yes\",\n  data: []\n};\n\nfor (let i = 0; i < contacts.length; i++) {\n    let contact = contacts[i];\n    let record = {\n        formId: \"party\",\n        entity: \"party\",\n        action: \"update\",\n        id: contact.ContactID || \"new\", // use ContactID if available, else \"new\"\n        formData: {\n            org_id: $('Prepare Database1').first().json.c_org_id,\n            integration:$('Prepare Database1').first().json.id,\n            name: contact.Name,\n            is_customer: contact.IsCustomer,\n            is_bank:  \"\",\n            is_vendor: contact.IsSupplier,\n            contact_id: contact.ContactID,\n            id: contact.ContactID || \"new\"\n        }\n    };\n    request.data.push(record);\n}\n\nreturn request;\n"
      },
