    {
      "parameters": {
        "jsCode": "let accounts = $input.first().json.Accounts; // array of contacts from Xero\n\nlet request = {\n  tenant_id: $('Prepare Database1').first().json.c_datasource,\n  saveOrUpdate: \"Yes\",\n  data: []\n};\n\nfor (let i = 0; i < accounts.length; i++) {\n    let account = accounts[i];\n    let record = {\n        formId: \"chart_of_accounts\",\n        entity: \"chart_of_accounts\",\n        action: \"update\",\n        id: account.AccountID || \"new\",\n        formData: {\n          org_id: $('Prepare Database1').first().json.c_org_id,\n            integration:$('Prepare Database1').first().json.id,\n            name: account.Name,\n            status: account.Status,\n            description: account?.Description,\n            code: account?.Code || \"\",\n            currency: account?.CurrencyCode||\"\",\n            tax_type:  account.TaxType?.toLowerCase(),\n            type:  account.Type?.toLowerCase(),\n          account_type:  account.Class?.toLowerCase(),\n            id: account.AccountID || \"new\"\n        }\n    };\n    request.data.push(record);\n}\n\nreturn request;\n"
      },
