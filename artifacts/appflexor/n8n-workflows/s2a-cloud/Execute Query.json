      "id": "b010ce16-c91f-4710-8846-5a7dbd97aa11",
      "name": "Complete Task",
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const items = [];\n\nfor (const item of $input.all()) {\n  let broken = item.json.variables.queries.value;\n  let fixed = broken\n  .replace(/(\\w+)\\s*:/g, '\"$1\":')                 // add quotes around keys\n  .replace(/(\\[)([0-9a-fA-F-]{36})(\\])/g, '[\"$2\"]'); // wrap UUIDs in quotes\n\nconst parsed = JSON.parse(fixed);\n  const dataKeys = parsed.dataKeys;\n  dataKeys.forEach(dk => {\n    if (Array.isArray(dk.serviceParams)) {\n      dk.serviceParams = dk.serviceParams.join(\",\"); // convert array to comma-separated string\n    }\n  });\n  items.push({      \n      tenant_id:item.json.variables.tenantId.value,\n      dataKeys\n    });\n}\n\nreturn items;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
