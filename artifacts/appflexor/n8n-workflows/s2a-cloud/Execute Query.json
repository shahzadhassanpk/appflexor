      "name": "Execute Query"
    },
    {
      "parameters": {
        "jsCode": "const items = [];\n\nfor (const item of $input.all()) {\n  const camundaVars = {};\n  const request = {taskId:$('Fetch and Lock').first().json.id,\n                  workerId:\"EXECUTE_QUERIES\"}\n  Object.entries(item.json.C_DATA).forEach(([key, value]) => {\n    camundaVars[key] = {\n      value: JSON.stringify(value),\n      type: \"Json\"  // use String for text values\n    };\n  });\n  request.variables = camundaVars;\n  items.push(request);  \n}\n\nreturn items;\n"
      },
