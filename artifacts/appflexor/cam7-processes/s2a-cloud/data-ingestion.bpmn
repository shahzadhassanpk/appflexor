  <bpmn:collaboration id="Collaboration_1k5jyir">
    <bpmn:participant id="Participant_0s7nf84" name="Bill Processing" processRef="data_ingestion" />
  </bpmn:collaboration>
  <bpmn:process id="data_ingestion" name="Data Ingestion" isExecutable="true" camunda:historyTimeToLive="1">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:extensionElements>
        <camunda:executionListener event="start">
          <camunda:script scriptFormat="javascript">execution.setVariable("auditEvent", "yes");</camunda:script>
        </camunda:executionListener>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_17ao32z</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_0rplbod" name="Extract Data" camunda:type="external" camunda:topic="data_ingestion">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_17ao32z</bpmn:incoming>
      <bpmn:outgoing>Flow_0vrbidy</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_1xi47uv">
      <bpmn:incoming>Flow_0c95ge2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Activity_0smsirw" name="Approve" camunda:formKey="document">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="action">APPROVED</camunda:outputParameter>
          <camunda:outputParameter name="comments">Seems good to approve</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1m666fe</bpmn:incoming>
      <bpmn:outgoing>Flow_0c95ge2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Activity_0c0livd" name="Review" camunda:formKey="document">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="action">APPROVED</camunda:outputParameter>
          <camunda:outputParameter name="comments">Seems good to review</camunda:outputParameter>
        </camunda:inputOutput>
        <camunda:executionListener event="end">
          <camunda:script scriptFormat="javascript">var status= execution.getVariable("status");
var executeTriggers = [
{"trigger":"update.doc.status", "serviceParams": status}
];
execution.setVariable("externalEvent", "yes");
execution.setVariable("executeTriggers", JSON.stringify(executeTriggers));</camunda:script>
        </camunda:executionListener>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_17zyl97</bpmn:incoming>
      <bpmn:outgoing>Flow_1m666fe</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_16zvhdr" name="Set Variables" camunda:type="external" camunda:topic="EXECUTE_QUERIES">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="queries">{
    dataKeys: [
                {
                    serviceParams: [${execution.processBusinessKey}],
                    dataKey: "formData",
                    serviceKey: "fetch.bill.details",
                    mode: "formData"
                }
            ]           
}</camunda:inputParameter>
        </camunda:inputOutput>
        <camunda:executionListener event="end">
          <camunda:script scriptFormat="javascript">var ArrayList = Java.type("java.util.ArrayList");
var auditKeys = new ArrayList();
auditKeys.add("status");
execution.setVariable("audit_keys", auditKeys);
var responseObj = JSON.parse(formData);
execution.setVariable("subject", responseObj[0].document_name);
execution.setVariable("dueDate", responseObj[0].due_date);
execution.setVariable("status", responseObj[0].status);</camunda:script>
        </camunda:executionListener>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0vrbidy</bpmn:incoming>
      <bpmn:outgoing>Flow_17zyl97</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_17ao32z" sourceRef="StartEvent_1" targetRef="Activity_0rplbod" />
    <bpmn:sequenceFlow id="Flow_0vrbidy" sourceRef="Activity_0rplbod" targetRef="Activity_16zvhdr" />
