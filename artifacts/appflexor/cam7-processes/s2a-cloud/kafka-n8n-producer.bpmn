  <bpmn:process id="kafka-n8n-producer" name="kafka-n8n-producer" isExecutable="true" camunda:historyTimeToLive="1">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_0hv2nrg</bpmn:outgoing>
