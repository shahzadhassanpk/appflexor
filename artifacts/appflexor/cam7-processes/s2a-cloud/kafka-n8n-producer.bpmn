    <bpmn:userTask id="Activity_0vw7s2u" name="Kafka Test" camunda:formKey="kafka-producer">
      <bpmn:extensionElements>
        <camunda:taskListener class="com.s2a.camunda7.plugins.KafkaTaskListener" event="complete" id="kafkaListener">
          <camunda:field name="task">
            <camunda:string>EXECUTE_TRIGGERS</camunda:string>
          </camunda:field>
          <camunda:field name="payload">
            <camunda:expression>[{"serviceKey":"trigger.update", "serviceParams":"hello;${execution.getBusinessKey()}"}]</camunda:expression>
          </camunda:field>
        </camunda:taskListener>
        <camunda:taskListener class="com.s2a.camunda7.plugins.KafkaTaskListener" event="create" id="kafkaListener">
          <camunda:field name="task">
            <camunda:string>EXECUTE_QUERIES</camunda:string>
          </camunda:field>
          <camunda:field name="payload">
            <camunda:expression>[{"serviceParams": "","dataKey": "profile","serviceKey": "sys.user.profile","mode": "formData"}]</camunda:expression>
          </camunda:field>
        </camunda:taskListener>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0hv2nrg</bpmn:incoming>
      <bpmn:outgoing>Flow_1117i3j</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="Event_0dplzhb">
      <bpmn:incoming>Flow_1117i3j</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
