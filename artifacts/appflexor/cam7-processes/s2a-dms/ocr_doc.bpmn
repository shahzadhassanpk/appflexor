    <bpmn:serviceTask id="Activity_1mi2r0v" name="Elastic Serach Indexing" camunda:type="external" camunda:topic="INDEXING_WORKER">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="queries">{
	"dataKeys": [
