    </bpmn:startEvent>
    <bpmn:userTask id="Activity_1cbjc2q" name="Quality Review" camunda:formKey="${form_key}">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_02qk7ko</bpmn:incoming>
      <bpmn:outgoing>Flow_136le6q</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_16zvhdr" name="Load Data" camunda:type="external" camunda:topic="EXECUTE_QUERIES">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="queries">{
    dataKeys: [
                {
                    serviceParams: [${execution.processBusinessKey}],
                    dataKey: "formData",
                    serviceKey: "fetch.doc.details",
                    mode: "formData"
                }
            ]           
}</camunda:inputParameter>
        </camunda:inputOutput>
        <camunda:executionListener event="end">
          <camunda:script scriptFormat="javascript">var responseObj = JSON.parse(formData);
execution.setVariable("file", responseObj[0].content);
execution.setVariable("prompt", responseObj[0].meta_prompt);
execution.setVariable("form_key", responseObj[0].form_key);</camunda:script>
        </camunda:executionListener>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1kih1yr</bpmn:incoming>
      <bpmn:outgoing>Flow_1ordhib</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_0m7jqm8" name="Process Document" camunda:type="external" camunda:topic="s2a_dms">
      <bpmn:incoming>Flow_1ordhib</bpmn:incoming>
