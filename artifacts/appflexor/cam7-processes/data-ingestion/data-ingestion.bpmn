    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0rvm6xh" name="Rejected" sourceRef="Gateway_1bjgfz4" targetRef="Event_019hac0">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${action == 'REJECTED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
