      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:extensionElements>
        <camunda:executionListener event="start">
          <camunda:script scriptFormat="javascript">var auditKeys = S(JSON.stringify(["action"]), "application/json");
var auditEvents = S(JSON.stringify(["create","assignment","complete"]), "application/json");
var taskEvents = S(JSON.stringify(["startEvent", "endEvent", "complete"]), "application/json");
var taskKeys = S(JSON.stringify(["action", "executeTriggers"]), "application/json");

execution.setVariable("auditKeys", auditKeys );
execution.setVariable("auditEvents", auditEvents);
execution.setVariable("taskKeys", taskKeys);
execution.setVariable("taskEvents", taskEvents);
execution.setVariable("enableTaskEvents", "yes");
execution.setVariable("enableAuditEvents", "yes");</camunda:script>
        </camunda:executionListener>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_17ao32z</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_0rplbod" name="OCR + AI Data Extraction" camunda:type="external" camunda:topic="data_ingestion">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_17ao32z</bpmn:incoming>
      <bpmn:outgoing>Flow_0vrbidy</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_16zvhdr" name="Set Context" camunda:type="external" camunda:topic="EXECUTE_QUERIES">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="queries">{
    dataKeys: [
                {
                    serviceParams: [${execution.processBusinessKey}],
                    dataKey: "formData",
                    serviceKey: "fetch.bill.details",
                    mode: "formData"
                }
            ]           
}</camunda:inputParameter>
        </camunda:inputOutput>
        <camunda:executionListener event="end">
          <camunda:script scriptFormat="javascript">var ArrayList = Java.type("java.util.ArrayList");
var auditKeys = new ArrayList();
auditKeys.add("status");
execution.setVariable("audit_keys", auditKeys);
var responseObj = JSON.parse(formData);
execution.setVariable("subject", responseObj[0].document_name);
execution.setVariable("dueDate", responseObj[0].due_date);
execution.setVariable("status", responseObj[0].status);</camunda:script>
        </camunda:executionListener>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0vrbidy</bpmn:incoming>
      <bpmn:outgoing>Flow_0p3rtv3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_0c0livd" name="Review" camunda:formKey="document">
      <bpmn:extensionElements>
        <camunda:taskListener event="complete">
          <camunda:script scriptFormat="javascript">// Get variables
var action = task.getVariable("action");
var businessKey = task.getExecution().getProcessBusinessKey();

// Default fallback if action is missing
if (!action) {
  action = 'UNKNOWN';
  task.setVariable("action", action);
}

// Compute status
var status = (action === 'APPROVED' ? 'REVIEWED' : 'REJECTED');
task.setVariable("status", status);

// Build trigger array
var executeTriggers = [
  {
    "serviceKey": "update.doc.status",
    "serviceParams": status + ";" + businessKey
  }
];

// Save as JSON string
task.setVariable("executeTriggers", JSON.stringify(executeTriggers));</camunda:script>
        </camunda:taskListener>
        <camunda:taskListener event="create">
          <camunda:script scriptFormat="javascript">task.setVariable("stage", "REVIEW");</camunda:script>
        </camunda:taskListener>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_14uyzs9</bpmn:incoming>
      <bpmn:incoming>Flow_0p3rtv3</bpmn:incoming>
      <bpmn:outgoing>Flow_1m666fe</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_1f6njo0" name="Action ?">
      <bpmn:incoming>Flow_1m666fe</bpmn:incoming>
      <bpmn:outgoing>Flow_0k7terp</bpmn:outgoing>
      <bpmn:outgoing>Flow_0800r3o</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Event_0pf5xo9" name="End">
      <bpmn:incoming>Flow_0800r3o</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Activity_0smsirw" name="Approve" camunda:formKey="document">
      <bpmn:extensionElements>
        <camunda:taskListener event="complete">
          <camunda:script scriptFormat="javascript">var action= task.getVariable("action");
var status = action;
var businessKey = task.getExecution().getProcessBusinessKey();
var executeTriggers = [
{"serviceKey":"update.doc.status", "serviceParams": status+";"+businessKey}
];
task.setVariable("executeTriggers", JSON.stringify(executeTriggers));</camunda:script>
        </camunda:taskListener>
        <camunda:taskListener event="create">
          <camunda:script scriptFormat="javascript">task.setVariable("action", "");
task.setVariable("stage", "APPROVAL");</camunda:script>
        </camunda:taskListener>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0k7terp</bpmn:incoming>
      <bpmn:outgoing>Flow_0c95ge2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_1bjgfz4" name="Action ?">
      <bpmn:incoming>Flow_0c95ge2</bpmn:incoming>
      <bpmn:outgoing>Flow_14uyzs9</bpmn:outgoing>
      <bpmn:outgoing>Flow_0mezn1o</bpmn:outgoing>
      <bpmn:outgoing>Flow_0rvm6xh</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_17ao32z" sourceRef="StartEvent_1" targetRef="Activity_0rplbod" />
    <bpmn:sequenceFlow id="Flow_0vrbidy" sourceRef="Activity_0rplbod" targetRef="Activity_16zvhdr" />
    <bpmn:sequenceFlow id="Flow_0p3rtv3" sourceRef="Activity_16zvhdr" targetRef="Activity_0c0livd" />
    <bpmn:sequenceFlow id="Flow_14uyzs9" name="Review" sourceRef="Gateway_1bjgfz4" targetRef="Activity_0c0livd">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${action == 'REVIEW'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1m666fe" sourceRef="Activity_0c0livd" targetRef="Gateway_1f6njo0" />
    <bpmn:sequenceFlow id="Flow_0k7terp" name="Reviewed" sourceRef="Gateway_1f6njo0" targetRef="Activity_0smsirw">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${action == 'APPROVED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0800r3o" name="Rejected" sourceRef="Gateway_1f6njo0" targetRef="Event_0pf5xo9">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${action == 'REJECTED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0c95ge2" sourceRef="Activity_0smsirw" targetRef="Gateway_1bjgfz4" />
    <bpmn:sequenceFlow id="Flow_0mezn1o" name="Approved" sourceRef="Gateway_1bjgfz4" targetRef="Activity_0g4pmai">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${action == 'APPROVED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_0ys39zd">
