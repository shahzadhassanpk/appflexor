  </bpmn:collaboration>
  <bpmn:process id="document_ingestion" name="Document Ingestion" isExecutable="true" camunda:historyTimeToLive="1">
    <bpmn:laneSet id="LaneSet_0ea73rm">
      <bpmn:lane id="Lane_19rzr79" name="Staff">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
