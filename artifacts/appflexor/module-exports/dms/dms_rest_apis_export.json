t \nwhere c_repository_id = ?\norder by c_doc_no","instance_id":"","createdby":"admin","datasource":"","servicekey":"get.doc.by.repo","modifiedby":"admin","id":"325d99aa-5853-4b29-95c9-c51c2520559e","attachements":"","createdbyname":"","desc":""},{"app":"rest-api","store_id":"","":"","modifiedbyname":"","business_key":"","params":"","sql":"select id, c_doc_no, c_name, c_title, c_description, c_parent_id, c_doc_type, c_content from app_fd_dms_document \nwhere id = ?\norder by c_doc_no","instance_id":"","createdby":"admin","datasource":"","servicekey":"get.doc.by.id","modifiedby":"admin","id":"47f49adc-eadb-4b5b-aeae-a8b6a1af0546","attachements":"","createdbyname":"","desc":""},{"app":"rest-api","store_id":"","":"","modifiedbyname":"","datecreated":"2025-04-10 15:22:06.682212","business_key":"","params":"","sql":"select id,username,firstname,lastname,email from dir_user \nwhere username = ?","instance_id":"","datemodified":"2025-04-16 13:03:59.626679","createdby":"admin","datasource":"","servicekey":"get.user.detail","modifiedby":"admin","id":"e516cdc9-55c4-4978-980c-b711a81c289f","attachements":"","createdbyname":"","desc":""},{"app":"rest-api","store_id":"","":"","modifiedbyname":"","business_key":"","params":"","sql":"select id, c_doc_no, c_name, c_title, c_description, c_parent_id, c_doc_type, c_content from app_fd_dms_document \nwhere c_parent_id = ?\norder by c_doc_no","instance_id":"","createdby":"admin","datasource":"","servicekey":"get.doc.by.folder","modifiedby":"admin","id":"115a78e5-05ad-4a59-834c-a3c5059322d5","attachements":"","createdbyname":"","desc":""},{"app":"rest-api","store_id":"","":"","modifiedbyname":"","datecreated":"2025-04-16 11:34:06.96668","business_key":"","params":"","sql":"SELECT dt.c_name as c_doc_type_name, \ndd.*, af.c_table, af.c_form_key, du.firstname, du.lastname,\n(select count(id) current_revision from app_fd_dms_doc_revision where c_doc_id=dd.id\ngroup by c_doc_id) as c_current_revision\nFROM app_fd_dms_document AS dd\n  Join app_fd_dms_doc_type As dt\n    left Join app_fd_process_map as onupdate on onupdate.id = dt.c_on_update\n  left Join app_fd_process_map as ondelete on ondelete.id = dt.c_on_delete\n  On dt.id = dd.c_doc_type\nJOIN app_fd_app_form AS af\n    ON\naf.id = dt.c_form_id\nLEFT JOIN dir_user AS du\n    ON\ndd.c_checked_out_by = du.username\nWHERE dd.id= ?","instance_id":"","datemodified":"2025-04-16 12:12:31.12477","createdby":"admin","datasource":"","servicekey":"rest.index.doc","modifiedby":"admin","id":"5ca8de39-ec6c-436d-b33c-4a7466cdb4eb","attachements":"","createdbyname":"","desc":""},{"app":"rest-api","store_id":"","":"","modifiedbyname":"","datecreated":"2025-04-16 12:12:54.128883","business_key":"","params":"","sql":"select ft.c_name as c_folder_type_name, r.c_name as c_repository_name,\nfolder.*, af.c_table, af.c_form_key\nfrom app_fd_dms_folder as folder\n  JOIN app_fd_dms_folder_type ft on ft.id=folder.c_folder_type\n  JOIN app_fd_app_form as af on af.id = ft.c_form_id\n  JOIN app_fd_dms_repository r on r.id=folder.c_repository_id\n  where folder.id= ?\n  and (folder.c_folder_type is not null and folder.c_folder_type<>'') and ft.c_form_id is not null","instance_id":"","datemodified":"2025-04-16 12:12:54.128883","createdby":"admin","datasource":"","servicekey":"rest.index.folder","modifiedby":"admin","id":"0f75d0f7-d016-4663-8d7a-2311ebb92292","attachements":"","createdbyname":"","desc":""},{"app":"rest-api","store_id":"","":"","modifiedbyname":"","datecreated":"2025-04-16 12:14:05.792886","business_key":"","params":"","sql":"select * from app_fd_dms_repository \nwhere id = ?","instance_id":"","datemodified":"2025-04-16 12:14:05.792886","createdby":"admin","datasource":"","servicekey":"rest.index.repo","modifiedby":"admin","id":"e444eaa1-34bb-40ef-b7ac-5049a7174c44","attachements":"","createdbyname":"","desc":""},{"app":"rest-api","store_id":"","":"","modifiedbyname":"","datecreated":"2025-04-17 12:49:03.349175","business_key":"","params":"","sql":"delete from dir_user_group where userid = ? and groupid = ?","instance_id":"","datemodified":"2025-04-17 12:51:00.104635","createdby":"admin","datasource":"","servicekey":"user.unassign.group","modifiedby":"admin","id":"ef6840bd-4df6-4af4-a663-4b19c3507bd1","attachements":"","createdbyname":"","desc":""},{"app":"rest-api","store_id":"","":"","modifiedbyname":"","datecreated":"2025-04-17 17:06:53.971801","business_key":"","params":"","sql":"delete from app_fd_dms_doc_permission where c_doc_id = ? and c_group = ? and c_permission = ?","instance_id":"","datemodified":"2025-04-17 17:07:04.217358","createdby":"admin","datasource":"","servicekey":"delete.doc.permission","modifiedby":"admin","id":"adb16a0d-2f27-4071-b401-8133a7aaddba","attachements":"","createdbyname":"","desc":""},{"app":"rest-api","store_id":"","":"","modifiedbyname":"","datecreated":"2025-04-17 17:07:37.274599","business_key":"","params":"","sql":"delete from app_fd_dms_folder_permission where c_folder_id = ? and c_group = ? and c_permission = ?","instance_id":"","datemodified":"2025-04-17 17:07:37.274599","createdby":"admin","datasource":"","servicekey":"delete.folder.permission","modifiedby":"admin","id":"028d836d-9117-4ebc-af92-7148b7b577cc","attachements":"","createdbyname":"","desc":""},{"app":"rest-api","store_id":"","":"","modifiedbyname":"","datecreated":"2025-04-17 17:43:08.53518","business_key":"","params":"","sql":"select u.username, p.c_permission from app_fd_dms_folder_permission p \njoin dir_user_group g on p.c_group=g.groupid \njoin dir_user u on u.id=g.userid\nwhere p.c_folder_id = ?\nand u.username='#currentUser.username#' and p.c_permission in ('0', '2')","instance_id":"","datemodified":"2025-04-17 18:07:18.080592","createdby":"admin","datasource":"","servicekey":"check.folder.permission","modifiedby":"admin","id":"e3d83091-4f7d-43b6-a9c4-dc09d40f5dd4","attachements":"","createdbyname":"","desc":""},{"app":"rest-api","store_id":"","":"","modifiedbyname":"","datecreated":"2025-04-17 18:11:58.957634",